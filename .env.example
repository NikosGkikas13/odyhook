# Database
DATABASE_URL="postgresql://hooksmith:hooksmith@localhost:5432/hooksmith?schema=public"

# Redis (for BullMQ delivery queue)
REDIS_URL="redis://localhost:6379"

# NextAuth v5
# Generate with: npx auth secret  OR  openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-strong-random-value"
AUTH_URL="http://localhost:3000"

# GitHub OAuth provider
# Create an OAuth App at https://github.com/settings/developers
# Callback URL must be: <AUTH_URL>/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email provider (magic link sign-in)
#
# Two options:
#  (a) Local capture via MailHog (docker-compose) — emails never leave your
#      machine; view them at http://localhost:8025. Leave USER/PASSWORD empty:
#        EMAIL_SERVER_HOST="localhost"
#        EMAIL_SERVER_PORT=1025
#        EMAIL_SERVER_USER=""
#        EMAIL_SERVER_PASSWORD=""
#        EMAIL_FROM="HookSmith <no-reply@hooksmith.local>"
#
#  (b) Real delivery via Resend SMTP — sign up at https://resend.com, create
#      an API key, then use:
#        EMAIL_SERVER_HOST="smtp.resend.com"
#        EMAIL_SERVER_PORT=465
#        EMAIL_SERVER_USER="resend"
#        EMAIL_SERVER_PASSWORD="re_xxxxxxxxxxxxxxxx"   # your API key
#        EMAIL_FROM="HookSmith <onboarding@resend.dev>"  # sandbox sender
#      For production, verify a domain in Resend and switch EMAIL_FROM to
#      an address on that domain (e.g. "no-reply@yourdomain.com").
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="HookSmith <no-reply@hooksmith.local>"

# 32-byte (base64) key used to encrypt destination headers and source signing secrets at rest
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="replace-me-with-base64-32-bytes"

# Public base URL used in copy-to-clipboard ingest URLs on the dashboard
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Circuit breaker: consecutive exhausted deliveries before auto-disabling a
# destination. Default 5; set to a lower number to trip earlier.
# DESTINATION_FAILURE_THRESHOLD=5
