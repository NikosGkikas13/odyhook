// Odyhook — webhook management platform
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Auth (NextAuth v5 / @auth/prisma-adapter) ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  // Account-wide alert defaults. Nullable = no defaults configured.
  // Per-destination overrides on Destination.alertConfigJson shallow-merge
  // on top of this. See src/lib/alerts/schema.ts for the shape.
  alertConfigJson Json?

  accounts     Account[]
  sessions     Session[]
  sources      Source[]
  destinations Destination[]
  apiKey       UserApiKey?
  apiTokens    ApiToken[]
}

// Bring-your-own-key: each user stores their own Anthropic API key so their
// Claude usage is billed to them, not the platform.
model UserApiKey {
  userId          String   @id
  anthropicKeyEnc String // encrypted with ENCRYPTION_KEY
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Programmatic access tokens for the public REST API (/api/v1). Distinct from
// UserApiKey (which holds the *encrypted* Anthropic BYOK key): API tokens are
// HASHED, not encrypted — we only ever verify a presented token, never recover
// it. A user can mint many; each is shown in full exactly once at creation.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String // human label: "my-laptop", "terraform"
  tokenHash  String    @unique // sha256(raw token), hex
  prefix     String // first chars shown in UI: "ody_a1b2"
  lastUsedAt DateTime?
  revokedAt  DateTime?
  expiresAt  DateTime? // optional hard expiry; enforced in authenticateApiToken
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Odyhook domain ----------

model Source {
  id            String   @id @default(cuid())
  userId        String
  name          String
  slug          String   @unique
  signingSecret String? // encrypted; optional HMAC verification
  verifyStyle   String? // "stripe" | "github" | "generic-sha256"
  // Per-source rate limit overrides. Null = fall back to env defaults.
  // `rateLimitPerSec` is the sustained refill rate in events per second.
  // `rateLimitBurst`  is the bucket capacity (max instantaneous burst).
  rateLimitPerSec Int?
  rateLimitBurst  Int?
  // Data-retention window in days. The purge job (src/scripts/purge.ts) deletes
  // events (and, by cascade, their deliveries) older than this many days.
  // Null = keep indefinitely. New sources default to 90 at the service layer;
  // pre-existing rows stay null so this change doesn't retroactively purge data.
  retentionDays Int?
  createdAt     DateTime @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      Event[]
  routes      Route[]
  fingerprint SchemaFingerprint?

  @@index([userId])
}

model Destination {
  id          String   @id @default(cuid())
  userId      String
  name        String
  url         String
  headersEnc  String? // encrypted JSON blob: { "X-Api-Key": "..." }
  timeoutMs   Int      @default(10000)
  // Operational pause. When false, ingest skips creating deliveries for this
  // destination and the worker refuses to deliver any already-enqueued job.
  enabled     Boolean  @default(true)
  // Optional outbound HMAC secret. When set, the worker signs each delivery
  // with HMAC-SHA256 over `${unix_ts}.${body}` and attaches
  // `X-Odyhook-Signature: v1=<hex>` + `X-Odyhook-Timestamp` so the downstream
  // receiver can verify it. Encrypted at rest like other secrets.
  outboundSecretEnc String?
  // Circuit-breaker state. Incremented on every exhausted delivery,
  // reset to 0 on every successful delivery, and used to flip `enabled`
  // to false once it crosses DESTINATION_FAILURE_THRESHOLD (default 5).
  consecutiveFailures Int       @default(0)
  // Set when the breaker tripped (not when an operator pauses manually).
  // Cleared by `toggleDestinationEnabled` on resume.
  autoDisabledAt      DateTime?
  autoDisabledReason  String?
  // Per-destination alert override. Partial shape — keys present here win
  // over User.alertConfigJson during effective-config resolution. Null =
  // inherit user defaults entirely. See src/lib/alerts/schema.ts.
  alertConfigJson     Json?
  createdAt   DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  routes     Route[]
  deliveries Delivery[]

  @@index([userId])
}

model Route {
  id            String   @id @default(cuid())
  sourceId      String
  destinationId String
  enabled       Boolean  @default(true)
  // M7 — NL-compiled filter AST. If non-null, events are only forwarded on
  // this route when the filter evaluates truthy. Evaluated deterministically
  // (no LLM at runtime).
  filterAst     Json?
  // M7 — original natural-language prompt used to compile filterAst (for UI display / re-edit).
  filterPrompt  String?
  createdAt     DateTime @default(now())

  source         Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  destination    Destination     @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  transformation Transformation?

  @@unique([sourceId, destinationId])
  @@index([sourceId])
}

// M5 — AI-generated payload transformation applied before forwarding.
// One transformation per route; if present, its JS runs in a QuickJS sandbox
// against the event body and the result is forwarded instead of the raw body.
model Transformation {
  id           String   @id @default(cuid())
  routeId      String   @unique
  prompt       String // plain-English description provided by the user
  codeJs       String // pure JS function body: `(event) => transformed`
  sampleInput  String? // the event payload used to preview/validate
  sampleOutput String? // last preview output
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
}

// M6 — cached Claude diagnosis for a failed delivery.
model AiDiagnosis {
  id         String   @id @default(cuid())
  deliveryId String   @unique
  summary    String
  detail     String
  modelUsed  String
  createdAt  DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

// M8 — cached Claude diff between two events on the same source.
// Keyed on (eventAId, eventBId) so repeated requests hit the cache.
model AiEventDiff {
  id        String   @id @default(cuid())
  eventAId  String // older event (by receivedAt)
  eventBId  String // newer event
  summary   String
  changes   Json // DiffChange[] — { path, kind, from?, to? }
  modelUsed String
  createdAt DateTime @default(now())

  eventA Event @relation("DiffEventA", fields: [eventAId], references: [id], onDelete: Cascade)
  eventB Event @relation("DiffEventB", fields: [eventBId], references: [id], onDelete: Cascade)

  @@unique([eventAId, eventBId])
}

// M7 — most recent structural fingerprint per source, used to detect drift
// when nightly sampling compares the current shape against this.
model SchemaFingerprint {
  sourceId    String   @id
  fingerprint Json
  generatedAt DateTime @default(now())

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Event {
  id          String   @id @default(cuid())
  sourceId    String
  method      String
  headersJson Json
  bodyRaw     String // raw request body as text
  receivedAt  DateTime @default(now())
  remoteIp    String?
  // Stable per-source dedupe key. Computed at ingest time from (in priority):
  //   1. Idempotency-Key request header
  //   2. Stripe `event.id` parsed from the body when verifyStyle="stripe"
  //   3. X-GitHub-Delivery header when verifyStyle="github"
  //   4. Fallback: sha256(body) hex
  // Nullable for rows created before this column existed. Combined with
  // sourceId in a unique index — Postgres allows multiple NULLs, so legacy
  // rows don't conflict with each other.
  idempotencyKey String?

  source     Source     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  deliveries Delivery[]
  diffsAsA   AiEventDiff[] @relation("DiffEventA")
  diffsAsB   AiEventDiff[] @relation("DiffEventB")

  @@unique([sourceId, idempotencyKey])
  @@index([sourceId, receivedAt])
}

enum DeliveryStatus {
  pending
  in_flight
  delivered
  failed
  exhausted
}

model Delivery {
  id                  String         @id @default(cuid())
  eventId             String
  destinationId       String
  status              DeliveryStatus @default(pending)
  attemptCount        Int            @default(0)
  responseCode        Int?
  responseBodySnippet String? // first 2KB
  lastError           String?
  nextRetryAt         DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  destination Destination  @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  diagnosis   AiDiagnosis?

  @@index([eventId])
  @@index([destinationId, status])
  // Backs the delivery reaper's stalled-row scan (status + age). Leading
  // `status` also serves the orphaned-in_flight branch, which filters by
  // updatedAt over the few in_flight rows that status seek selects.
  @@index([status, createdAt])
}
